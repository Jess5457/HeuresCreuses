<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A14"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Heures Creuses"
            android:textColor="#E8E8F0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure tes plages horaires"
            android:textColor="#5A5A7A"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Statut actuel -->
        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/status_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHARGEMENT"
                android:textColor="#00E5A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/status_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prochain changement : --:--"
                android:textColor="#5A5A7A"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Plages configurées -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TES PLAGES HEURES CREUSES"
            android:textColor="#5A5A7A"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/plages_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp" />

        <!-- Bouton ajouter -->
        <Button
            android:id="@+id/btn_add"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="+ Ajouter une plage"
            android:textColor="#00E5A0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_add_background"
            android:layout_marginBottom="12dp" />

        <!-- Bouton sauvegarder -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enregistrer et mettre à jour le widget"
            android:textColor="#0A0A14"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_save_background"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
